{
  "name": "@cowprotocol/sdk-common",
  "version": "0.8.2",
  "description": "Common utilities and types for CoW Protocol SDK",
  "repository": {
    "type": "git",
    "url": "https://github.com/cowprotocol/cow-sdk.git",
    "directory": "packages/common"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "dist/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cowprotocol/sdk-config": "1.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.31",
    "@types/jest": "^29.4.0",
    "tsup": "^7.2.0",
    "typescript": "^5.2.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.0.0",
    "@cow-sdk/typescript-config": "0.0.0-beta.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  }
}